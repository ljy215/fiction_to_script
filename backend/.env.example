APP_ENV=development
APP_NAME=AI Novel To Script API
APP_VERSION=0.1.0

# Alibaba Bailian API configuration.
# Keep real API keys in local .env or deployment secrets only.
BAILIAN_API_KEY=dev-placeholder-bailian-api-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus

# Replace this value in real environments.
JWT_SECRET=dev-only-change-me-before-production-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=sqlite:///./storage/data/app.sqlite3
FILE_STORAGE_DIR=./storage/files

# Comma-separated origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
